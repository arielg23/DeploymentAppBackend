# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/smartlock

# Security
SECRET_KEY=change-this-to-a-long-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Admin seed account (used only on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# CORS - comma-separated origins (use * for dev)
ALLOWED_ORIGINS=*
